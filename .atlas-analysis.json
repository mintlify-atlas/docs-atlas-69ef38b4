  "keyFeatures": [
    "Drag-and-drop visual editor with iframe canvas",
    "Extensible plugin system for adding custom functionality",
    "Component model with custom types and behaviors",
    "Built-in Style Manager with CSS property sectors",
    "Block Manager for reusable drag-and-drop content",
    "Multi-page support with Page Manager",
    "Asset Manager for media library management",
    "Data Sources for dynamic data binding to components",
    "Responsive design with Device Manager and media queries",
    "Storage Manager with local and remote persistence",
    "Internationalization (i18n) support",
    "Undo/Redo history management",
    "Rich Text Editor integration with customizable RTE"
  ],
  "publicApiSurface": [
